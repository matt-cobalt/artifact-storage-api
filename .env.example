# Artifact Storage API — backend (Railway / local)
# Copy to .env and set in Railway dashboard for production.

# Railway sets PORT automatically. For local dev with Hybrid POS (Next.js on 3000), use 3001.
PORT=3001

# Supabase (required for DB and artifact storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Anthropic (for agent execution)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional: app URL for links in emails/webhooks
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Optional: Stripe (if using payment agents)
# STRIPE_SECRET_KEY=sk_...

# Optional: Slack alerts
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# SLACK_ALERT_WEBHOOK_URL=...
# PAGERDUTY_INTEGRATION_KEY=...
# ALERT_EMAIL_RECIPIENTS=email@example.com
